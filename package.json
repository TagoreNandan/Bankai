{
  "name": "my-app",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "@types/react": "^19.2.17"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:native": "turbo -F native dev"
  },
  "dependencies": {
    "@my-app/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@my-app/config": "workspace:*",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.2.21"
}
